    if(size!=='All sizes' && !p.tags.some(t=> extractSize(t) === size)) return false;
    return true;
  });

  if(sortPrice === 'asc' || sortPrice === 'desc'){
    list = list.slice().sort((a,b)=>{
      const pa = minPrice(a.price), pb = minPrice(b.price);
      return sortPrice === 'asc' ? pa - pb : pb - pa;
    });
  }

  list.forEach(p=>{
    const badge = p.status==='active' ? '<span class="badge badge-active">Active</span>' : '<span class="badge badge-pending">Pending</span>';
    grid.innerHTML += `
      <div class="partner-card" data-id="${p.id}">
