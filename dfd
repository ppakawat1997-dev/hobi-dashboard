// Forward-fill empty Company values for Sheet 2 (handles Google Sheets merged cells)
// If a row has a Partner ID but empty Company, look for the company name
// from a previous row with the SAME Partner ID, or fall back to Sheet 1.
function forwardFillSheet2Company(rows){
  let lastCompanyByPartner = {};
  
  // First pass: build a map of partnerId -> company from rows that DO have company
  rows.forEach(r=>{
    if(r.partnerId && r.company && r.company.trim()){
      lastCompanyByPartner[r.partnerId] = r.company.trim();
    }
  });
  
  // Also check Sheet 1 as a fallback source
  sheet1Rows.forEach(p=>{
    if(p.partnerId && p.company && p.company.trim() && !lastCompanyByPartner[p.partnerId]){
      lastCompanyByPartner[p.partnerId] = p.company.trim();
    }
  });
  
  let filledCount = 0;
  rows.forEach(r=>{
    if(r.partnerId && (!r.company || !r.company.trim())){
      if(lastCompanyByPartner[r.partnerId]){
        r.company = lastCompanyByPartner[r.partnerId];
        filledCount++;
      }
    }
  });
  
  console.log(`🔧 Forward-filled ${filledCount} empty Company cells from merged-cell groups`);
  return rows;
}

