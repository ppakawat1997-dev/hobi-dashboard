      saveSheet2();
      // Reset filter dropdown
      const filterSelect = document.getElementById('s2FilterSelect');
      if(filterSelect) filterSelect.value = '';
      renderSheet2('');  // No filter!
      console.log('✅ Loaded Sheet 2:', sheet2Rows.length, 'rows');
    }
    
    document.getElementById('importPreviewModal').classList.remove('active');
    alert(`✓ Successfully loaded ${rows.length} rows into Sheet ${sheetNum}!`);
  } catch(err){
    console.error('Load error:', err);
    alert('Error: ' + err.message);
  }
}

// Sync both sheets to All Partners
function syncBothSheets(){
  console.log('🔄 syncBothSheets called!');
  console.log('Sheet1Rows:', sheet1Rows.length, 'Sheet2Rows:', sheet2Rows.length);
  
  if(sheet2Rows.filter(r=>r.partnerId||r.type).length === 0){
    alert('Add at least one equipment row in Sheet 2 before syncing.');
    return;
  }

  // Build merged CSV from sheet1 + sheet2 (long format per equipment row)
  const csvLines = ['partner Id,Company,Type,Model,Quantity,Price Per day,Remark'];
  
  sheet2Rows.forEach(eq=>{
    if(!eq.partnerId && !eq.type) return;
    const partner = sheet1Rows.find(p=> p.partnerId === eq.partnerId);
    const company = (eq.company && eq.company.trim()) ? eq.company : (partner ? partner.company : '');
    const line = [eq.partnerId, company, eq.type, eq.model, eq.quantity, eq.price, eq.remark]
      .map(v=> `"${(v||'').toString().replace(/"/g,'""')}"`)
      .join(',');
    csvLines.push(line);
  });

  try{
    const csv = csvLines.join('\n');
    console.log('Built CSV with', csvLines.length - 1, 'equipment lines');
    
    // Parse to long-format groups, then merge with Sheet1 contact info
    const groups = parseLongFormatCSV(csv);
    console.log('Grouped into', groups.length, 'partners');
    
    // Merge Sheet1 contact data into each group
    groups.forEach(g=>{
      const sh1Partner = sheet1Rows.find(p=> p.partnerId === g.sourceId);
      if(sh1Partner){
        if(sh1Partner.contact) g.contact = sh1Partner.contact;
        if(sh1Partner.phone) g.phone = sh1Partner.phone;
        if(sh1Partner.email) g.email = sh1Partner.email;
        if(sh1Partner.area) g.area = sh1Partner.area;
        if(sh1Partner.status) g.status = sh1Partner.status;
        if(sh1Partner.location) g.address = sh1Partner.location;
        if(sh1Partner.lat) g.lat = parseFloat(sh1Partner.lat);
        if(sh1Partner.lng) g.lng = parseFloat(sh1Partner.lng);
      }
    });

    // Now build partners array from enriched groups
    partners = [];
    partnerIdCounter = 0;
    let added = 0;
    const statusDebug = [];
    
    groups.forEach(g=>{
      const numericId = parseInt(g.sourceId);
      const newId = !isNaN(numericId) ? numericId : ++partnerIdCounter;
      const normalized = normalizeStatus(g.status) || 'pending';
      statusDebug.push({
        partnerId: g.sourceId,
        company: g.name || `Partner ${g.sourceId}`,
        rawStatus: g.status || '(empty)',
        normalized: normalized
      });
      partners.push({
        id: newId,
        _sheetId: g.sourceId,
        name: g.name || `Partner ${g.sourceId}`,
        contact: g.contact || '',
        phone: g.phone || '',
        email: g.email || '',
        area: normalizeArea(g.area) || 'กรุงเทพ',
        status: normalized,
        tags: g.tags,
        price: g.price || '0 - 0',
        lat: (!isNaN(g.lat) && g.lat) ? g.lat : null,
        lng: (!isNaN(g.lng) && g.lng) ? g.lng : null,
        address: g.address || '', 
        notes: ''
      });
      if(!isNaN(numericId) && newId > partnerIdCounter) partnerIdCounter = newId;
      added++;
    });

    // Include Sheet 1 partners that have NO equipment rows in Sheet 2 —
    // otherwise they'd be silently dropped from All Partners entirely.
    let addedNoEquip = 0;
    sheet1Rows.forEach(p1=>{
      if(!p1.partnerId || !p1.partnerId.trim()) return;
      const alreadyIncluded = partners.some(p=> p._sheetId === p1.partnerId);
      if(alreadyIncluded) return;

      const numericId = parseInt(p1.partnerId);
      const newId = !isNaN(numericId) ? numericId : ++partnerIdCounter;
      const normalized = normalizeStatus(p1.status) || 'pending';
      statusDebug.push({
        partnerId: p1.partnerId,
        company: p1.company || `Partner ${p1.partnerId}`,
        rawStatus: p1.status || '(empty)',
        normalized: normalized
      });
      partners.push({
        id: newId,
        _sheetId: p1.partnerId,
        name: p1.company || `Partner ${p1.partnerId}`,
        contact: p1.contact || '',
        phone: p1.phone || '',
        email: p1.email || '',
        area: normalizeArea(p1.area) || 'กรุงเทพ',
        status: normalized,
        tags: [],
        price: '0 - 0',
        lat: (parseFloat(p1.lat) || null),
        lng: (parseFloat(p1.lng) || null),
        address: p1.location || '',
        notes: p1.remark || ''
      });
      if(!isNaN(numericId) && newId > partnerIdCounter) partnerIdCounter = newId;
      added++;
      addedNoEquip++;
    });

    if(addedNoEquip > 0){
      console.log(`ℹ️ ${addedNoEquip} partner(s) from Sheet 1 had NO equipment rows in Sheet 2 — added with empty equipment list:`);
      console.table(statusDebug.slice(-addedNoEquip));
    }

    console.log('✅ Created', added, 'partners');

    // Status verification table — open browser console (F12) to inspect
    const activeCount = statusDebug.filter(d=>d.normalized==='active').length;
    const pendingCount = statusDebug.filter(d=>d.normalized==='pending').length;
    console.log(`📊 Status breakdown: ${activeCount} active (signed), ${pendingCount} pending`);
    console.log('Partners marked ACTIVE (signed):');
    console.table(statusDebug.filter(d=>d.normalized==='active'));
    console.log('Full status mapping for ALL partners (raw → normalized):');
    console.table(statusDebug);

    // Flag partners whose raw status text exists but DIDN'T match "active" —
    // these are the most likely candidates for a missed signed-contract row.
    const unmatchedNonEmpty = statusDebug.filter(d=>
      d.normalized === 'pending' && d.rawStatus && d.rawStatus !== '(empty)'
    );

    renderPartners();
    rebuildMap();
    rebuildSummaries();
    saveSheet1();
    saveSheet2();
    showView('partners');

    let msg = `Synced ✓ — ${added} partner(s) created from Sheets 1 & 2.\n\n✅ Signed contract: ${activeCount}\n⏳ Pending: ${pendingCount}`;
    if(addedNoEquip > 0){
      msg += `\n\nℹ️ ${addedNoEquip} partner(s) from Sheet 1 had no equipment listed in Sheet 2 (added with empty equipment list):\n`;
      msg += statusDebug.slice(-addedNoEquip).map(d=> `• ${d.company} (#${d.partnerId})`).join('\n');
    }
    if(unmatchedNonEmpty.length){
      msg += `\n\n⚠️ ${unmatchedNonEmpty.length} partner(s) have a non-empty status that was read as PENDING. If any of these should be "signed", their raw text is:\n`;
      msg += unmatchedNonEmpty.slice(0,10).map(d=> `• ${d.company} (#${d.partnerId}): "${d.rawStatus}"`).join('\n');
      if(unmatchedNonEmpty.length > 10) msg += `\n...and ${unmatchedNonEmpty.length-10} more (see console F12)`;
    }
    alert(msg);
  } catch(err){
    console.error('Sync error:', err);
    alert('Error: ' + (err.message || 'Could not sync this data.'));
  }
}

// ================= FIRESTORE SHARED SYNC =================

function applyRemoteData(data){
  if(!data) return;
  isApplyingRemote = true;
  try{
    // Guard: ignore an empty/missing partners array from the cloud if we
    // currently have real local data — prevents a bad/partial write from
    // ever wiping out good data on someone else's screen.
    const incomingPartnersOk = Array.isArray(data.partners) && (data.partners.length > 0 || partners.length === 0);
    if(incomingPartnersOk) partners = data.partners;
    if(Array.isArray(data.sheet1Rows)) sheet1Rows = data.sheet1Rows;
    if(Array.isArray(data.sheet2Rows)) sheet2Rows = data.sheet2Rows;
    if(typeof data.partnerIdCounter === 'number') partnerIdCounter = data.partnerIdCounter;

    // Re-render everything with the new data
    renderPartners();
    rebuildMap();
    rebuildSummaries();
    renderSheet1();
    renderSheet2();

    // Keep localStorage as an offline cache too (so a fresh page load
    // never has to fall back to the hardcoded sample data)
    try{
      localStorage.setItem('hobi_sheet1', JSON.stringify(sheet1Rows));
      localStorage.setItem('hobi_sheet2', JSON.stringify(sheet2Rows));
      localStorage.setItem('hobi_partners', JSON.stringify(partners));
    }catch(e){}

    showSaveStatus('🔄 Synced from cloud');
  } finally {
    // small delay so our own listener doesn't immediately re-trigger a save
    setTimeout(()=>{ isApplyingRemote = false; }, 300);
  }
}

function saveAllToFirestore(){
  if(!firebaseReady || !HOBI_DOC) return;
  if(isApplyingRemote) return; // don't echo back what we just received
  if(!initialLoadComplete){
    console.warn('⏳ Skipping save — initial Firestore load not finished yet (prevents overwriting cloud data with local defaults)');
    return;
  }
  clearTimeout(firestoreSaveTimer);
  firestoreSaveTimer = setTimeout(()=>{
    // Cache locally first, regardless of cloud outcome
    try{ localStorage.setItem('hobi_partners', JSON.stringify(partners)); }catch(e){}
    HOBI_DOC.set({
      partners,
      sheet1Rows,
      sheet2Rows,
      partnerIdCounter,
      updatedAt: firebase.firestore.FieldValue.serverTimestamp()
    }, {merge:true})
    .then(()=> showSaveStatus('✓ Synced to cloud'))
    .catch(err=>{
      console.error('Firestore save failed:', err);
      showSaveStatus('✗ Cloud sync failed — saved locally only');
    });
  }, 600); // debounce rapid edits
}

// Hook saveAllToFirestore into the existing save points
const _origSaveSheet1 = saveSheet1;
saveSheet1 = function(){ _origSaveSheet1(); saveAllToFirestore(); };
const _origSaveSheet2 = saveSheet2;
saveSheet2 = function(){ _origSaveSheet2(); saveAllToFirestore(); };

// Partner card add/edit (submitAdd), delete, and clear-all also need to push to cloud
document.getElementById('submitAdd').addEventListener('click', ()=> saveAllToFirestore());
document.getElementById('resetBtn').addEventListener('click', ()=> saveAllToFirestore());
document.getElementById('importFile').addEventListener('change', ()=> setTimeout(saveAllToFirestore, 200));

const _origDeletePartner = deletePartner;
deletePartner = function(id){
  const before = partners.length;
  _origDeletePartner(id);
  if(partners.length !== before) saveAllToFirestore();
};

// ---- Initial load + real-time listener ----
function showCloudErrorBanner(msg){
  let banner = document.getElementById('cloudErrorBanner');
  if(!banner){
    banner = document.createElement('div');
    banner.id = 'cloudErrorBanner';
    banner.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#fef3c7;color:#92400e;padding:8px 16px;text-align:center;font-size:13px;z-index:9999;border-bottom:1px solid #fbbf24;';
    document.body.prepend(banner);
  }
  banner.innerHTML = `⚠️ ${msg} — showing last saved data on this device. Changes may not sync to other users until this is resolved.`;
}

if(firebaseReady && HOBI_DOC){
  HOBI_DOC.get().then(snap=>{
    if(snap.exists){
      console.log('☁️ Loaded shared data from Firestore');
      applyRemoteData(snap.data());
    } else {
      console.log('☁️ No shared data yet — seeding Firestore with current data');
      initialLoadComplete = true; // allow this seed write
      saveAllToFirestore();
    }
    initialLoadComplete = true;
    handleRoute(); // open any deep-linked partner now that data is ready

    // Real-time listener for changes from other users
    HOBI_DOC.onSnapshot(snap=>{
      if(!snap.exists) return;
      if(isApplyingRemote) return;
      console.log('☁️ Remote update received');
      applyRemoteData(snap.data());
    }, err=>{
      console.error('Firestore listener error:', err);
      showCloudErrorBanner('Lost connection to shared database');
    });
  }).catch(err=>{
    console.error('Firestore load failed:', err);
    showCloudErrorBanner('Could not reach shared database (' + (err.code||err.message) + ')');
    initialLoadComplete = true; // allow local edits to still work / cache locally
    handleRoute();
  });
} else {
  initialLoadComplete = true;
  if(!firebaseReady) showCloudErrorBanner('Cloud sync unavailable (Firebase failed to load)');
  handleRoute();
}


// ================= ROUTING (#/partners/:id deep links) =================

function handleRoute(){
  const hash = location.hash || '';
  const m = hash.match(/^#\/partners\/(\d+)/);
  if(m){
    const id = parseInt(m[1]);
    if(partners.some(p=>p.id===id)){
      showView('partners');
      openDetailPartner(id);
    }
  }
}

window.addEventListener('hashchange', handleRoute);

// Update URL hash when opening/closing partner detail (deep-linkable)
const _origOpenDetailPartner = openDetailPartner;
openDetailPartner = function(id){
  _origOpenDetailPartner(id);
  if(location.hash !== `#/partners/${id}`){
    history.pushState(null, '', `#/partners/${id}`);
  }
};

document.getElementById('detailClose').addEventListener('click', ()=>{
  if(location.hash.startsWith('#/partners/')){
    history.pushState(null, '', location.pathname + location.search);
  }
});
