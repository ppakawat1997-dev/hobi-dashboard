  document.getElementById('d_area').textContent = p.area || '-';

  const emailRow = document.getElementById('d_email_row');
  document.getElementById('d_email').textContent = p.email || '-';
  emailRow.style.display = 'flex';

  const addrRow = document.getElementById('d_address_row');
  if(p.address){ addrRow.style.display='block'; document.getElementById('d_address').textContent = p.address; }
  else addrRow.style.display='none';

  const notesRow = document.getElementById('d_notes_row');
  if(p.notes){ notesRow.style.display='block'; document.getElementById('d_notes').textContent = p.notes; }
  else notesRow.style.display='none';

  // Parse each tag: "Type x5 (Model) @price" -> {type, qty, model, price}
  const parsed = (p.tags||[]).map(t=>{
    const price = tagPrice(t);
    const base = tagDisplayText(t);
    const m = base.match(/^(.+?)\s*x(\d+)(?:\s*\((.*)\))?$/);
    if(m){
      return { type: m[1].trim(), qty: parseInt(m[2])||0, model: (m[3]||'').trim(), price };
    }
    return { type: base, qty: 1, model: '', price };
  });

  // Build equipment summary grouped by Type (sum quantities, track price range)
  const grouped = {};
  parsed.forEach(item=>{
    if(!grouped[item.type]) grouped[item.type] = {qty:0, count:0, prices:[]};
    grouped[item.type].qty += item.qty;
    grouped[item.type].count += 1;
    if(!isNaN(item.price)) grouped[item.type].prices.push(item.price);
  });

  const summaryHtml = Object.entries(grouped).map(([type, g])=> {
    let priceLabel = '-';
    if(g.prices.length){
      const min = Math.min(...g.prices), max = Math.max(...g.prices);
      priceLabel = min === max
        ? `${min.toLocaleString()} ฿/day`
        : `${min.toLocaleString()} - ${max.toLocaleString()} ฿/day`;
    }
    return `
    <div class="equip-summary-card">
      <div>
        <div class="label">${type}</div>
        <div class="count">${g.count} model${g.count>1?'s':''} · ${g.qty} unit${g.qty>1?'s':''}</div>
      </div>
      <div class="price">${priceLabel}</div>
    </div>`;
  }).join('');
  document.getElementById('d_equip_summary').innerHTML = summaryHtml || '<div style="font-size:12px; color:var(--text3);">No equipment listed</div>';

  const totalUnits = parsed.reduce((sum,item)=> sum + item.qty, 0);
  document.getElementById('d_total_units').textContent = `${totalUnits} unit${totalUnits!==1?'s':''}`;

  // Equipment detail table rows
  document.getElementById('d_tags').innerHTML = parsed.map(item=> `
    <tr>
      <td>${item.type}</td>
      <td>${item.qty}</td>
      <td>${!isNaN(item.price) ? item.price.toLocaleString() : '-'}</td>
      <td style="color:var(--text2);">${item.model || '-'}</td>
    </tr>`).join('') || '<tr><td colspan="4" style="color:var(--text3); text-align:center;">No equipment listed</td></tr>';

  document.getElementById('d_price').textContent = `Price: ${p.price} THB / day`;

  detailEditId = id;
  document.getElementById('detailModal').style.display = 'flex';
}

