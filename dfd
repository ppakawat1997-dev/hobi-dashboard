function buildCsvUrls(input){
  const gid = extractGid(input);
  const urls = [];
  // Real spreadsheet ID from a normal /d/{id}/edit link or a bare ID
  const m = input.match(/\/d\/([a-zA-Z0-9-_]+)/);
  const id = m ? m[1] : (/^[a-zA-Z0-9-_]{20,}$/.test(input) && !input.includes('/') ? input : null);
  if(id && id !== 'e'){
    // gviz endpoint supports CORS — best chance of working without a proxy
    urls.push(`https://docs.google.com/spreadsheets/d/${id}/gviz/tq?tqx=out:csv&gid=${gid}`);
    urls.push(`https://docs.google.com/spreadsheets/d/${id}/export?format=csv&gid=${gid}`);
  }
  // Published-to-web link (/d/e/{pubid}/pubhtml) — no CORS, needs a proxy
  const pub = input.match(/\/d\/e\/([a-zA-Z0-9-_]+)/);
  if(pub){
    urls.push(`https://docs.google.com/spreadsheets/d/e/${pub[1]}/pub?output=csv&gid=${gid}`);
  }
  return urls;
}

function extractGid(input){
  const m = input.match(/[#&?]gid=(\d+)/);
  return m ? m[1] : '0';
}

async function fetchSheetCSV(urls){
  // 1) Try each candidate URL directly (gviz supports CORS and usually works)
  for(const url of urls){
    try{
      const res = await fetch(url);
      if(res.ok){
        const text = await res.text();
        if(text && !text.trim().startsWith('<')) return text;
      }
    } catch(e){ /* fall through */ }
  }
  // 2) Try public CORS proxies for links that don't send CORS headers (/pub?output=csv)
  const proxies = [
    u => `https://api.allorigins.win/raw?url=${encodeURIComponent(u)}`,
    u => `https://corsproxy.io/?url=${encodeURIComponent(u)}`,
    u => `https://thingproxy.freeboard.io/fetch/${u}`
  ];
  for(const url of urls){
    for(const buildProxyUrl of proxies){
      try{
        const res = await fetch(buildProxyUrl(url));
        if(res.ok){
          const text = await res.text();
          if(text && !text.trim().startsWith('<')) return text;
        }
      } catch(e){ /* try next */ }
    }
  }
  throw new Error('CORS_BLOCKED');
}

