<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hobi - Partner Management</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tabler-icons/2.44.0/iconfont/tabler-icons.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.js"></script>
<style>
  :root{
    --bg:#f0f0f0; --card:#ffffff; --border:#d4d4d8; --text:#27272a; --text2:#71717a; --text3:#a1a1aa;
    --blue:#c81e1e; --blue-light:#fbe0e0; --green:#16a34a; --green-light:#e6f7ec;
    --amber:#d97706; --amber-light:#fef3e2; --pink:#db4f9b; --pink-light:#fdeaf3;
  }
  [data-theme="dark"]{
    --bg:#18181b; --card:#27272a; --border:#3f3f46; --text:#f4f4f5; --text2:#a1a1aa; --text3:#71717a;
    --blue:#f87171; --blue-light:#3a1515; --green:#34d27a; --green-light:#15301f;
    --amber:#f5a623; --amber-light:#3a2c10; --pink:#ec6fb0; --pink-light:#3a1f2c;
  }
  body, .partner-card, .form-card, .stat-card, .modal-box, .side-card, .btn, input, select, textarea{
    transition: background-color .2s, border-color .2s, color .2s;
  }
  *{box-sizing:border-box; font-family:-apple-system,"Segoe UI",Roboto,Arial,sans-serif;}
  html{color-scheme:light;}
  html[data-theme="dark"]{color-scheme:dark;}
  input::placeholder, textarea::placeholder{color:var(--text3);}
  select{color-scheme:inherit;}
  body{margin:0; background:var(--bg); color:var(--text);}
  .app{display:flex; min-height:100vh;}
  /* Sidebar */
  .sidebar{width:220px; background:var(--card); border-right:1px solid var(--border); display:flex; flex-direction:column; flex-shrink:0;}
  .logo{display:flex; align-items:center; gap:10px; padding:20px 18px; font-weight:600; font-size:17px;}
  .logo i{font-size:22px; color:var(--blue);}
  .nav{display:flex; flex-direction:column; gap:2px; padding:0 10px;}
  .nav-item{display:flex; align-items:center; gap:10px; padding:10px 12px; border-radius:8px; color:var(--text2); font-size:14px; cursor:pointer; text-decoration:none;}
  .nav-item i{font-size:18px;}
  .nav-item.active{background:var(--blue-light); color:var(--blue); font-weight:500;}
  .nav-item:hover:not(.active){background:var(--bg);}
  .sidebar-footer{margin-top:auto; padding:16px 18px; border-top:1px solid var(--border); display:flex; align-items:center; gap:10px;}
  .avatar{width:34px; height:34px; border-radius:50%; background:var(--blue-light); color:var(--blue); display:flex; align-items:center; justify-content:center; font-weight:600; font-size:14px;}
  .user-name{font-size:13px; font-weight:500;}
  .user-email{font-size:11px; color:var(--text3);}

  /* Main */
  .main{flex:1; padding:24px 28px; min-width:0;}
  .header{display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:20px; flex-wrap:wrap; gap:12px;}
  .header h1{font-size:22px; margin:0 0 4px;}
  .header p{margin:0; color:var(--text2); font-size:13px;}
  .header-actions{display:flex; gap:8px; flex-wrap:wrap;}
  .btn{display:flex; align-items:center; gap:6px; padding:8px 14px; border-radius:8px; border:1px solid var(--border); background:var(--card); font-size:13px; color:var(--text); cursor:pointer; white-space:nowrap;}
  .btn:hover{background:var(--bg);}
  .btn-primary{background:var(--blue); color:#fff; border-color:var(--blue);}
  .btn-primary:hover{background:#2659c9;}

  /* Stats */
  .stats{display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:20px;}
  .stat-card{background:var(--card); border:1px solid var(--border); border-radius:12px; padding:16px; display:flex; align-items:center; gap:12px;}
  .stat-icon{width:42px; height:42px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0;}
  .stat-value{font-size:20px; font-weight:600; line-height:1.2;}
  .stat-label{font-size:12px; color:var(--text2);}

  /* Filters */
  .filters{display:flex; gap:10px; margin-bottom:20px; flex-wrap:wrap;}
  .search-box{flex:1; min-width:220px; position:relative;}
  .search-box i{position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text3); font-size:16px;}
  .search-box input{width:100%; padding:9px 12px 9px 36px; border:1px solid var(--border); border-radius:8px; font-size:13px; background:var(--card);}
  select{padding:9px 12px; border:1px solid var(--border); border-radius:8px; font-size:13px; background:var(--card); color:var(--text); cursor:pointer;}

  /* Partner cards */
  .partners-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:14px;}
  .partner-card{background:var(--card); border:1px solid var(--border); border-radius:12px; padding:16px; display:flex; flex-direction:column; gap:8px; cursor:pointer; transition:border-color .15s, box-shadow .15s; position:relative;}
  .partner-card:hover{border-color:var(--blue); box-shadow:0 2px 10px rgba(200,30,30,0.12);}
  .card-actions{display:flex; gap:6px;}
  .card-action-btn{width:28px; height:28px; border-radius:7px; border:1px solid var(--border); background:var(--card); color:var(--text2); display:flex; align-items:center; justify-content:center; font-size:14px; cursor:pointer; flex-shrink:0;}
  .card-action-btn:hover{background:var(--bg);}
  .card-action-btn.danger:hover{background:#fdeaea; color:var(--pink); border-color:#fdeaea;}
  .partner-top{display:flex; justify-content:space-between; align-items:flex-start; gap:8px;}
  .partner-name{font-size:14px; font-weight:600;}
  .partner-contact{font-size:12px; color:var(--text2); margin-top:2px;}
  .badge{font-size:11px; font-weight:500; padding:3px 10px; border-radius:20px; white-space:nowrap;}
  .badge-active{background:var(--green-light); color:var(--green);}
  .badge-pending{background:var(--amber-light); color:var(--amber);}
  .partner-info{display:flex; align-items:center; gap:6px; font-size:12.5px; color:var(--text2);}
  .partner-info i{font-size:15px; color:var(--text3);}
  .partner-tags{display:flex; gap:6px; flex-wrap:wrap; padding-top:8px; border-top:1px solid var(--border); margin-top:4px;}
  .tag{font-size:11px; background:var(--bg); color:var(--text2); padding:3px 8px; border-radius:6px; line-height:1.4;}
  .partner-price{font-size:13px; font-weight:600; color:var(--blue); margin-top:2px;}

  /* Views */
  .view{display:none;}
  .view.active{display:block;}

  /* Map view */
  .map-layout{display:grid; grid-template-columns:1fr 260px; gap:14px;}
  #map{height:520px; border-radius:12px; border:1px solid var(--border); z-index:0;}
  [data-theme="dark"] #map .leaflet-tile-pane{filter:invert(1) hue-rotate(180deg) brightness(0.9) contrast(0.9);}
  [data-theme="dark"] .leaflet-popup-content-wrapper, [data-theme="dark"] .leaflet-popup-tip{background:var(--card); color:var(--text);}
  [data-theme="dark"] .leaflet-container a.leaflet-popup-close-button{color:var(--text2);}
  [data-theme="dark"] .leaflet-bar a{background:var(--card); color:var(--text); border-color:var(--border);}
  [data-theme="dark"] .leaflet-bar a:hover{background:var(--bg);}
  [data-theme="dark"] .leaflet-control-attribution{background:var(--card); color:var(--text2);}
  .legend{display:flex; gap:16px; font-size:12px; color:var(--text2); margin-bottom:12px; align-items:center;}
  .legend span{display:flex; align-items:center; gap:6px;}
  .dot{width:9px; height:9px; border-radius:50%; display:inline-block;}
  .side-card{background:var(--card); border:1px solid var(--border); border-radius:12px; padding:14px; margin-bottom:14px;}
  .side-card h3{font-size:13px; margin:0 0 10px; font-weight:600;}
  .area-row{display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid var(--border); font-size:13px;}
  .area-row:last-child{border-bottom:none;}
  .area-row .sub{font-size:11px; color:var(--text3);}
  .area-row .val{font-weight:600; color:var(--blue);}
  .equip-row{display:flex; justify-content:space-between; padding:6px 0; font-size:13px;}

  /* Modal */
  .modal-overlay{display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); align-items:center; justify-content:center; z-index:1000;}
  .modal-box{background:var(--card); border-radius:12px; width:560px; max-width:92vw; max-height:85vh; overflow:auto; padding:22px;}

  /* Detail modal v2 - card-style layout */
  .detail-grid{display:grid; grid-template-columns:1.4fr 1fr; gap:14px; margin:16px 0;}
  @media (max-width: 640px){ .detail-grid{grid-template-columns:1fr;} }
  .detail-card{background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:14px;}
  .detail-card h4{margin:0 0 12px; font-size:13px; display:flex; align-items:center; gap:6px; color:var(--text);}
  .detail-field-grid{display:grid; grid-template-columns:1fr 1fr; gap:12px;}
  .detail-field label{display:block; font-size:11px; color:var(--text3); margin-bottom:2px;}
  .detail-field div{font-size:13px; color:var(--text); display:flex; align-items:center; gap:6px;}
  .detail-divider{border-top:1px solid var(--border); margin:12px 0; padding-top:12px;}
  .equip-summary-card{display:flex; justify-content:space-between; align-items:center; background:var(--card); border:1px solid var(--border); border-radius:8px; padding:10px 12px; margin-bottom:8px;}
  .equip-summary-card .label{font-size:13px; font-weight:600; color:var(--text);}
  .equip-summary-card .count{font-size:11px; color:var(--text3);}
  .equip-summary-card .price{font-size:13px; font-weight:700; color:var(--blue);}
  .equip-total-row{display:flex; justify-content:space-between; padding-top:8px; border-top:1px solid var(--border); font-size:13px; font-weight:600;}
  .detail-table{width:100%; border-collapse:collapse; margin-top:8px; font-size:12.5px;}
  .detail-table th{text-align:left; padding:8px 10px; color:var(--text3); font-weight:600; border-bottom:1px solid var(--border); font-size:11px; text-transform:uppercase;}
  .detail-table td{padding:10px 10px; border-bottom:1px solid var(--border); color:var(--text);}
  .detail-table tr:last-child td{border-bottom:none;}
  .modal-box h2{font-size:17px; margin:0 0 4px;}
  .modal-box .sub{font-size:13px; color:var(--text2); margin:0 0 16px;}
  .modal-box table{width:100%; border-collapse:collapse; font-size:12px; margin-bottom:14px;}
  .modal-box th, .modal-box td{border:1px solid var(--border); padding:6px 8px; text-align:left; white-space:nowrap;}
  .modal-box th{background:var(--bg); font-weight:600;}
  .modal-note{display:flex; gap:8px; align-items:flex-start; background:var(--blue-light); color:var(--blue); font-size:12.5px; padding:10px 12px; border-radius:8px; margin-bottom:16px;}
  .modal-note i{font-size:16px; margin-top:1px;}
  .modal-actions{display:flex; justify-content:flex-end; gap:8px;}

  /* Add Partner form */
  .form-header{display:flex; align-items:center; gap:14px; margin-bottom:20px;}
  .back-btn{display:flex; align-items:center; justify-content:center; width:34px; height:34px; border-radius:8px; border:1px solid var(--border); background:var(--card); cursor:pointer; color:var(--text);}
  .back-btn:hover{background:var(--bg);}
  .form-header h1{font-size:20px; margin:0;}
  .form-card{background:var(--card); border:1px solid var(--border); border-radius:12px; padding:20px 22px; margin-bottom:16px;}
  .form-card h2{font-size:14px; margin:0 0 16px; font-weight:600;}
  .form-row{display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;}
  .form-group{display:flex; flex-direction:column; gap:6px;}
  .form-group label{font-size:13px; font-weight:500;}
  .form-group label .req{color:var(--pink);}
  .form-group input, .form-group select, .form-group textarea{padding:9px 12px; border:1px solid var(--border); border-radius:8px; font-size:13px; font-family:inherit; color:var(--text); background:var(--card);}
  .form-group input::placeholder, .form-group textarea::placeholder{color:var(--text3);}
  .form-group textarea{resize:vertical; min-height:60px;}
  .equip-header{display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;}
  .equip-header h2{margin:0;}
  .equip-table{display:grid; grid-template-columns:1fr 1fr 70px 100px 1fr 32px; gap:10px; align-items:end;}
  .equip-table .col-label{font-size:12px; color:var(--text2); margin-bottom:6px;}
  .equip-row-form{background:var(--bg); border-radius:10px; padding:14px; margin-bottom:10px;}
  .remove-equip{display:flex; align-items:center; justify-content:center; width:32px; height:32px; border-radius:8px; border:1px solid var(--border); background:var(--card); color:var(--text2); cursor:pointer;}
  .remove-equip:hover{background:#fdeaea; color:var(--pink); border-color:#fdeaea;}
  .form-actions{display:flex; justify-content:flex-end; gap:10px;}

  /* Raw data table */
  .raw-toolbar{display:flex; gap:8px; flex-wrap:wrap; margin-bottom:14px; align-items:center;}
  .raw-toolbar .spacer{flex:1;}
  .raw-table-wrap{background:var(--card); border:1px solid var(--border); border-radius:12px; overflow:auto; max-height:600px;}

  /* Table sizing controls */
  .table-size-controls{display:flex; gap:16px; align-items:center; margin-bottom:12px; padding:12px; background:var(--bg); border-radius:8px; flex-wrap:wrap;}
  .size-control-group{display:flex; gap:8px; align-items:center;}
  .size-control-group label{font-size:12px; color:var(--text2); white-space:nowrap; min-width:60px;}
  .size-control-group input[type="range"]{width:120px; cursor:pointer;}
  .size-control-group span{font-size:12px; color:var(--text3); min-width:50px; text-align:right;}

  /* Import Preview Modal */
  .preview-modal{display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:1000; justify-content:center; align-items:center; pointer-events:auto;}
  .preview-modal.active{display:flex;}
  .preview-content{background:var(--card); border-radius:12px; max-width:90vw; max-height:85vh; overflow:auto; padding:20px; width:90%; max-width:1000px; pointer-events:auto;}
  .preview-header{display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; border-bottom:1px solid var(--border); padding-bottom:12px;}
  .preview-header h3{margin:0; color:var(--text);}
  .preview-close{background:none; border:none; font-size:24px; cursor:pointer; color:var(--text2); padding:0; width:32px; height:32px; display:flex; align-items:center; justify-content:center;}
  .preview-close:hover{color:var(--text);}

  /* Column Mapping */
  .column-mapper{margin-bottom:16px; padding:12px; background:var(--bg); border-radius:8px; border:1px solid var(--border);}
  .column-mapper h4{margin:0 0 12px 0; font-size:13px; color:var(--text); text-transform:uppercase;}
  .column-mappings{display:grid; gap:10px;}
  .column-map-row{display:flex; gap:10px; align-items:center;}
  .column-map-row select{padding:8px 10px; border:1px solid var(--border); border-radius:6px; font-size:13px; background:var(--card); color:var(--text); flex:1; cursor:pointer;}
  .column-map-row span{font-size:12px; color:var(--text3); min-width:80px;}

  /* Data Checklist */
  .data-checklist{margin-top:16px; padding:12px; background:var(--bg); border-radius:8px; border:1px solid var(--border);}
  .data-checklist h4{margin:0 0 12px 0; font-size:13px; color:var(--text); text-transform:uppercase;}
  .checklist-items{display:flex; flex-direction:column; gap:8px;}
  .checklist-item{display:flex; gap:8px; align-items:center; padding:8px; background:var(--card); border-radius:6px; font-size:12px; color:var(--text2);}
  .checklist-item.ok{border-left:3px solid var(--green); color:var(--green);}
  .checklist-item.warning{border-left:3px solid var(--amber); color:var(--amber);}
  .checklist-item.error{border-left:3px solid var(--pink); color:var(--pink);}
  .checklist-icon{font-size:16px; width:20px; text-align:center;}

  /* Preview Table */
  .preview-table{width:100%; border-collapse:collapse; margin-top:12px; font-size:12px;}
  .preview-table th, .preview-table td{border:1px solid var(--border); padding:8px 10px; text-align:left;}
  .preview-table th{background:var(--bg); font-weight:600; color:var(--text);}
  .preview-table td{color:var(--text2);}
  .preview-table tr:nth-child(even) td{background:var(--bg);}
  .preview-table .empty{color:var(--text3); font-style:italic;}

  /* Load button enhancement */
  #previewLoadBtn{pointer-events:auto; cursor:pointer;}
  #previewLoadBtn:hover{transform:translateY(-1px); box-shadow:0 4px 12px rgba(59, 130, 246, 0.3);}
  #previewLoadBtn:active{transform:translateY(0);}
  #previewLoadBtn:disabled{opacity:0.5; cursor:not-allowed;}
  table.raw-table{width:100%; border-collapse:collapse; font-size:13px; min-width:900px;}
  table.raw-table th, table.raw-table td{border:1px solid var(--border); padding:0; text-align:left;}
  table.raw-table th{background:var(--bg); font-weight:600; padding:8px 10px; position:sticky; top:0; white-space:nowrap; font-size:12px;}
  table.raw-table td[contenteditable]{padding:7px 10px; min-width:90px; outline:none; color:var(--text);}
  table.raw-table td[contenteditable]:focus{background:var(--blue-light);}
  table.raw-table td.raw-del{width:40px; text-align:center; cursor:pointer; color:var(--text3); padding:7px; background:var(--bg); border-left:1px solid var(--border);}
  table.raw-table td.raw-del:hover{color:var(--pink); background:var(--pink-light);}
  table.raw-table th:last-child{background:var(--bg); position:sticky; right:0; z-index:10; border-left:1px solid var(--border);}
  .raw-paste-box{display:none; margin-bottom:14px;}
  .raw-paste-box textarea{width:100%; min-height:120px; padding:10px 12px; border:1px solid var(--border); border-radius:8px; font-size:12.5px; font-family:var(--font-mono, monospace); background:var(--card); color:var(--text); resize:vertical;}
  .raw-paste-actions{display:flex; gap:8px; margin-top:8px;}

  /* Sheet tabs */
  .raw-tab{border:none; background:transparent; padding:10px 14px; font-size:13.5px; cursor:pointer; color:var(--text2); border-bottom:2px solid transparent; margin-bottom:-2px; transition:all 0.2s;}
  .raw-tab:hover{color:var(--text);}
  .raw-tab.active{color:var(--blue); border-bottom-color:var(--blue); font-weight:500;}
  .raw-sheet{display:none;}
  .raw-sheet.active{display:block;}


  @media (max-width:1100px){
    .stats{grid-template-columns:repeat(2,1fr);}
    .partners-grid{grid-template-columns:repeat(2,1fr);}
    .map-layout{grid-template-columns:1fr;}
  }
  @media (max-width:680px){
    .sidebar{display:none;}
    .partners-grid{grid-template-columns:1fr;}
    .stats{grid-template-columns:1fr 1fr;}
  }
</style>
</head>
<body>
<div class="app">

  <!-- Sidebar -->
  <div class="sidebar">
    <div class="logo"><i class="ti ti-truck-loading"></i> Hobi</div>
    <div class="nav">
      <div class="nav-item active" data-view="partners"><i class="ti ti-layout-grid"></i> All Partners</div>
      <div class="nav-item" data-view="map"><i class="ti ti-map-2"></i> Service Area Map</div>
      <div class="nav-item" data-view="raw"><i class="ti ti-table"></i> Raw Data</div>
      <div class="nav-item" id="themeToggle"><i class="ti ti-moon" id="themeIcon"></i> <span id="themeLabel">Dark mode</span></div>
    </div>
    <div class="sidebar-footer">
      <div class="avatar">PP</div>
      <div>
        <div class="user-name">Pakawat Promduangdee</div>
        <div class="user-email">pakawatproms@gmail.com</div>
      </div>
    </div>
  </div>

  <!-- Main -->
  <div class="main">

    <!-- ================= PARTNERS VIEW ================= -->
    <div class="view active" id="view-partners">
      <div class="header">
        <div>
          <h1>Partners</h1>
          <p>Manage data for partners who provide rental equipment</p>
        </div>
        <div class="header-actions">
          <input type="file" id="importFile" accept=".csv" style="display:none;">
          <button class="btn" id="resetBtn"><i class="ti ti-trash"></i> Clear all</button>
          <button class="btn btn-primary" id="openAddPartner"><i class="ti ti-plus"></i> Add partner</button>
        </div>
      </div>

      <div class="stats">
        <div class="stat-card">
          <div class="stat-icon" style="background:var(--blue-light); color:var(--blue);"><i class="ti ti-building"></i></div>
          <div><div class="stat-value" id="statTotalPartners">7</div><div class="stat-label">Total partners</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon" style="background:var(--green-light); color:var(--green);"><i class="ti ti-rosette-discount-check"></i></div>
          <div><div class="stat-value" id="statActive">5</div><div class="stat-label">Signed contract</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon" style="background:var(--pink-light); color:var(--pink);"><i class="ti ti-users"></i></div>
          <div><div class="stat-value" id="statPending">2</div><div class="stat-label">Pending</div></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon" style="background:var(--amber-light); color:var(--amber);"><i class="ti ti-truck"></i></div>
          <div><div class="stat-value" id="statEquipment">37</div><div class="stat-label">Total equipment</div></div>
        </div>
      </div>

      <div class="filters">
        <div class="search-box"><i class="ti ti-search"></i><input type="text" placeholder="Search company name..." id="search"></div>
        <select id="filterCategory">
