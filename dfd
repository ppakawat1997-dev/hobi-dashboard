function parseSheetText(text){
  text = text.replace(/^\uFEFF/, '');
  // Trim only trailing whitespace/newlines, keep leading structure intact
  text = text.replace(/\s+$/, '');
  
  const firstLineEnd = text.indexOf('\n');
  const firstLine = firstLineEnd >= 0 ? text.substring(0, firstLineEnd) : text;
  const delim = firstLine.includes('\t') ? '\t' : ',';
  
  let parsedRows, headers;
  if(delim === '\t'){
    // Google Sheets paste: tab-separated, but cells can contain literal
    // newlines when a cell has wrapped/multi-line text. Google Sheets
    // wraps such cells in double quotes (like CSV), so use the same
    // quote-aware state machine, just with '\t' as the field delimiter.
    const allRows = [];
    let row = [];
    let cur = '';
    let inQuotes = false;
    
    for(let i = 0; i < text.length; i++){
      const ch = text[i];
      const next = text[i+1];
      
      if(inQuotes){
        if(ch === '"'){
          if(next === '"'){ cur += '"'; i++; }
          else inQuotes = false;
        } else {
          cur += ch;
        }
      } else {
        if(ch === '"' && cur === ''){
          inQuotes = true;
        } else if(ch === '\t'){
          row.push(cur.trim());
          cur = '';
        } else if(ch === '\r'){
          // skip
        } else if(ch === '\n'){
          row.push(cur.trim());
          cur = '';
          if(row.some(c => c !== '')) allRows.push(row);
          row = [];
        } else {
          cur += ch;
        }
      }
    }
    if(cur !== '' || row.length > 0){
      row.push(cur.trim());
      if(row.some(c => c !== '')) allRows.push(row);
    }
    
    headers = (allRows[0] || []).map(h=> h.trim());
    parsedRows = allRows.slice(1).map(cells=>{
      const obj = {};
      headers.forEach((h,idx)=> obj[h] = cells[idx] !== undefined ? cells[idx] : '');
      return obj;
    });
  } else {
    const {headers:h, rows} = parseRawCSV(text);
    headers = h;
    parsedRows = rows;
  }
  const filtered = parsedRows.filter(r=> Object.values(r).some(v=>v && v.toString().trim()!==''));
  return {rows: filtered, headers};
}

