function downloadCSV(content, filename){
  const blob = new Blob([content], {type:'text/csv;charset=utf-8;'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename;
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

function parseRawCSV(text){
  text = text.replace(/^\uFEFF/, '');
  
  // Parse the ENTIRE text as a state machine to handle quoted fields 
  // that may contain commas, newlines, and escaped quotes
  const allRows = [];
  let row = [];
  let cur = '';
  let inQuotes = false;
  
  for(let i = 0; i < text.length; i++){
    const ch = text[i];
    const next = text[i+1];
    
    if(inQuotes){
      if(ch === '"'){
        if(next === '"'){ cur += '"'; i++; } // escaped quote
        else inQuotes = false; // end quote
      } else {
        cur += ch; // includes newlines inside quotes
      }
    } else {
      if(ch === '"'){
        inQuotes = true;
      } else if(ch === ','){
        row.push(cur.trim());
        cur = '';
      } else if(ch === '\r'){
        // skip, handle on \n
      } else if(ch === '\n'){
        row.push(cur.trim());
        cur = '';
        // Only push row if it has content (avoid trailing empty rows)
        if(row.some(c => c !== '')) allRows.push(row);
        row = [];
      } else {
        cur += ch;
      }
    }
  }
  // Push final cell/row if any content remains
  if(cur !== '' || row.length > 0){
    row.push(cur.trim());
    if(row.some(c => c !== '')) allRows.push(row);
  }
  
  if(allRows.length === 0) return {headers: [], rows: []};
  
  const headers = allRows[0].map(h=> h.replace(/^\uFEFF/, '').trim());
  const rows = [];
  for(let i=1;i<allRows.length;i++){
    const cells = allRows[i];
    const obj = {};
    headers.forEach((h,idx)=> obj[h] = cells[idx] !== undefined ? cells[idx] : "");
    rows.push(obj);
  }
  return {headers, rows};
}

function parseCSV(text){
  const {rows} = parseRawCSV(text);
  return rows.map(obj=>({
    id: obj.id ? parseInt(obj.id) : null,
    name: obj.name, contact: obj.contact, phone: obj.phone, email: obj.email||'', area: obj.area,
    status: (obj.status||'active').toLowerCase(),
    tags: obj.tags ? obj.tags.split(';').map(t=>t.trim()).filter(Boolean) : [],
    price: obj.price, lat: parseFloat(obj.lat) || 13.7563, lng: parseFloat(obj.lng) || 100.5018,
    address: obj.address||'', notes: obj.notes||''
  })).filter(p=> p.name && p.name.trim()!=='');
}

// Detect a "long" sheet: one row per vehicle, grouped by a partner id column
// (e.g. Thai headers: partner Id, ชื่อบริษัท, ประเภท, รายละเอียดรถ, จำนวน)
function findHeader(headers, patterns){
  return headers.find(h => patterns.some(p => p.test(h)));
}

function isLongFormat(headers, rows){
  // Standard English template → not long format
  const hasStandardName = headers.some(h=>/^name$/i.test(h));
  const hasStandardTags = headers.some(h=>/^tags$/i.test(h));
  if(hasStandardName && hasStandardTags) return false;

  const idCol = findHeader(headers, [/partner\s*id/i, /^id$/i]);
  const nameCol = findHeader(headers, [/ชื่อบริษัท/, /บริษัท/, /company/i, /^name$/i]);
  const vehicleCol = findHeader(headers, [/ประเภท/, /^type$/i, /รายละเอียด/, /model/i, /จำนวน/, /qty/i, /quantity/i]);

  // Strong signal: there's an id column whose values repeat across rows
  if(idCol && rows && rows.length){
    const ids = rows.map(r=> (r[idCol]||'').toString().trim()).filter(Boolean);
    const hasDupes = new Set(ids).size < ids.length;
    if(hasDupes && (nameCol || vehicleCol)) return true;
  }

  // Fallback: looks like a vehicle-per-row sheet (no standard name/tags headers)
  return !!(idCol && nameCol && vehicleCol && !hasStandardName);
}

function parseLongFormatCSV(text){
  const {headers, rows} = parseRawCSV(text);
  const idCol = findHeader(headers, [/partner\s*id/i, /^id$/i]);
  const nameCol = findHeader(headers, [/ชื่อบริษัท/, /บริษัท/, /company/i, /^name$/i]);
  const contactCol = findHeader(headers, [/ผู้ติดต่อ/, /ติดต่อ/, /ผู้ประสานงาน/, /poc/i, /contact/i]);
  const typeCol = findHeader(headers, [/ประเภท/, /^type$/i]);
  const detailCol = findHeader(headers, [/รายละเอียด/, /model/i, /detail/i]);
  const qtyCol = findHeader(headers, [/จำนวน/, /qty/i, /quantity/i]);
  const priceCol = findHeader(headers, [/ราคา/, /price/i]);
  const areaCol = findHeader(headers, [/พื้นที่/, /จังหวัด/, /^area$/i]);
  const phoneCol = findHeader(headers, [/เบอร์/, /โทร/, /phone/i]);
  const statusCol = findHeader(headers, [/สถานะ/, /status/i]);
  const emailCol = findHeader(headers, [/อีเมล/, /email/i]);
  const addressCol = findHeader(headers, [/ที่อยู่/, /address/i]);
  const latCol = findHeader(headers, [/lat/i, /ละติจูด/]);
  const lngCol = findHeader(headers, [/lng/i, /lon/i, /ลองจิจูด/]);

  const groups = {};
  rows.forEach(r=>{
    const rawId = (r[idCol]||'').toString().trim();
    if(!rawId) return;
    if(!groups[rawId]) groups[rawId] = {rows:[]};
    groups[rawId].rows.push(r);
  });

  return Object.entries(groups).map(([rawId, g])=>{
    const first = g.rows[0];
    const tags = g.rows.map(r=>{
      const type = (typeCol && r[typeCol]) ? r[typeCol].trim() : 'Equipment';
      const qty = (qtyCol && r[qtyCol]) ? r[qtyCol].trim() : '1';
      const model = (detailCol && r[detailCol]) ? r[detailCol].trim() : '';
      const price = priceCol ? parseFloat(String(r[priceCol]).replace(/[^\d.]/g,'')) : NaN;
      const base = model ? `${type} x${qty} (${model})` : `${type} x${qty}`;
      return !isNaN(price) ? `${base} @${price}` : base;
    });
    const prices = g.rows.map(r=> priceCol ? parseFloat(String(r[priceCol]).replace(/[^\d.]/g,'')) : NaN).filter(v=>!isNaN(v));
    const priceStr = prices.length
      ? `${Math.min(...prices).toLocaleString()} - ${Math.max(...prices).toLocaleString()}`
      : null;

    return {
      sourceId: rawId,
      name: nameCol ? (first[nameCol]||'').trim() : '',
      contact: contactCol ? (first[contactCol]||'').trim() : '',
      phone: phoneCol ? (first[phoneCol]||'').trim() : '',
      email: emailCol ? (first[emailCol]||'').trim() : '',
      area: areaCol ? (first[areaCol]||'').trim() : '',
      status: statusCol ? normalizeStatus(first[statusCol]) : null,
      address: addressCol ? (first[addressCol]||'').trim() : '',
      lat: latCol ? parseFloat(first[latCol]) : NaN,
      lng: lngCol ? parseFloat(first[lngCol]) : NaN,
      tags,
      price: priceStr
    };
  });
}

// Auto-detect format (long Thai per-vehicle vs standard one-row-per-partner) and merge into partners.
// Returns {updated, added}. Throws if no usable rows.
function mergeCSVText(text, options){
  options = options || {};
  const {headers, rows} = parseRawCSV(text);
  let updated = 0, added = 0;

  if(options.replace){
    partners = [];
    partnerIdCounter = 0;
  }

  if(isLongFormat(headers, rows)){
    const groups = parseLongFormatCSV(text);
    if(!groups.length) throw new Error('No rows found. Check that the sheet has a partner ID column and at least one equipment row per partner.');
    groups.forEach(g=>{
      const numericId = parseInt(g.sourceId);
      let idx = !isNaN(numericId) ? partners.findIndex(x=>x.id===numericId) : -1;
      if(idx===-1) idx = partners.findIndex(x=> x._sheetId===g.sourceId);

      if(idx>-1){
        partners[idx].tags = g.tags;
        if(g.price) partners[idx].price = g.price;
        if(g.name) partners[idx].name = g.name;
        if(g.contact) partners[idx].contact = g.contact;
        if(g.phone) partners[idx].phone = g.phone;
        if(g.email) partners[idx].email = g.email;
        if(g.area) partners[idx].area = g.area;
        if(g.status) partners[idx].status = g.status;
        if(g.address) partners[idx].address = g.address;
        if(!isNaN(g.lat)) partners[idx].lat = g.lat;
        if(!isNaN(g.lng)) partners[idx].lng = g.lng;
        partners[idx]._sheetId = g.sourceId;
        updated++;
      } else {
        const newId = !isNaN(numericId) ? numericId : ++partnerIdCounter;
        partners.push({
          id: newId,
          _sheetId: g.sourceId,
          name: g.name || `Partner ${g.sourceId}`,
          contact: g.contact || '',
          phone: g.phone || '',
          email: g.email || '',
          area: normalizeArea(g.area) || 'กรุงเทพ',
          status: g.status || 'pending',
          tags: g.tags,
          price: g.price || '0 - 0',
          lat: !isNaN(g.lat) ? g.lat : 13.7563,
          lng: !isNaN(g.lng) ? g.lng : 100.5018,
          address: g.address || '', notes: ''
        });
        if(newId > partnerIdCounter) partnerIdCounter = newId;
        added++;
      }
    });
  } else {
    const imported = parseCSV(text);
    if(!imported.length) throw new Error('Could not recognize the columns. Expected either the standard headers (id, name, contact, phone, ...) or a Thai sheet with a partner ID column plus ชื่อบริษัท / ประเภท / รายละเอียดรถ. No valid rows were found.');
    imported.forEach(p=>{
      if(p.id && partners.some(x=>x.id===p.id)){
        const idx = partners.findIndex(x=>x.id===p.id);
        partners[idx] = {...partners[idx], ...p};
        updated++;
      } else {
        const newId = p.id || ++partnerIdCounter;
        p.id = newId;
        partners.push(p);
        if(newId > partnerIdCounter) partnerIdCounter = newId;
        added++;
      }
    });
  }
  return {updated, added};
}

