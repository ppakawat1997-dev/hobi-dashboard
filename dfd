// Normalize Thai/English contract status values to 'active' or 'pending'
function normalizeStatus(raw){
  if(!raw) return null;
  const s = raw.toString().trim().toLowerCase();
  if(!s) return null;
  // Pending / not-yet-signed indicators checked FIRST.
  // "ไม่" (not), "รอ" (waiting), "ยังไม่" (not yet) all negate "signed".
  // e.g. "รอเซ็นสัญญา" / "ยังไม่เซ็น" / "ไม่ได้เซ็น" all contain "เซ็น"
  // but mean PENDING, not active — so negation words win.
  if(/ไม่|รอ|pending|wait|^no$|^n$|^0$|^false$/i.test(s)) return 'pending';
  // Active / signed indicators (Thai + English)
  if(/เซ็น|signed|sign|active|ลงนาม|สำเร็จ|complete|done|^yes$|^y$|^1$|^true$|✓|✔|มีสัญญา/i.test(s)) return 'active';
  if(s === 'active' || s === 'pending') return s;
  return null;
}

// Extract the lowest number from a price range string like "6,000 - 8,000"
function minPrice(priceStr){
  if(!priceStr) return Infinity;
  const nums = String(priceStr).match(/[\d,]*\.?\d+/g);
  if(!nums || !nums.length) return Infinity;
  return Math.min(...nums.map(n=> parseFloat(n.replace(/,/g,''))));
}

// Approximate centroid coordinates for Thai provinces (Bangkok metro area).
// Used as a fallback when a partner has no lat/lng of their own — so they
// still appear on the Service Area Map, grouped near their province.
const AREA_CENTROIDS = {
  'กรุงเทพ': [13.7563, 100.5018],
  'ปทุมธานี': [14.0208, 100.5250],
  'นนทบุรี': [13.8622, 100.5135],
  'สมุทรปราการ': [13.5990, 100.5998],
  'สมุทรสาคร': [13.5475, 100.2740],
  'นครปฐม': [13.8200, 100.0400],
};

// Deterministic small jitter so multiple partners in the same province
// don't render as a single overlapping marker — spreads them in a ~6km radius.
function jitterCoord(base, seed){
  const angle = (seed * 137.5) % 360 * (Math.PI/180); // golden-angle spread
  const radius = 0.02 + (seed % 5) * 0.008; // ~2-6km in degrees
  return [base[0] + Math.cos(angle)*radius, base[1] + Math.sin(angle)*radius];
}

// Get a usable [lat,lng] for a partner: real coords if present, else
// an area-based approximate position. Returns null only if neither
// real coords NOR a recognized area are available.
function getDisplayCoords(p){
  if(p.lat != null && p.lng != null && !isNaN(p.lat) && !isNaN(p.lng) && p.lat && p.lng){
    return [p.lat, p.lng];
  }
  const area = normalizeArea(p.area);
  const base = AREA_CENTROIDS[area];
  if(!base) return null;
  return jitterCoord(base, p.id || 0);
}

// Tag format: "Type x5 (Model) @price" — @price is optional, used internally for per-type pricing
function tagDisplayText(tag){
  return tag.replace(/\s*@[\d.]+$/, '');
}
function tagPrice(tag){
  const m = tag.match(/@([\d.]+)$/);
  return m ? parseFloat(m[1]) : NaN;
}

// Dynamically populate Category and Area filter dropdowns based on actual data
// Extract size/model text from a tag — handles nested parens like "(รถขุดขนาด 3 ตัน (PC30))"
function extractSize(tag){
  const base = tagDisplayText(tag);
  const m = base.match(/\((.+)\)$/);
  return m ? m[1].trim() : null;
}

function rebuildFilterOptions(){
  // Collect unique equipment types (from tags, e.g. "รถเครน x1 (...)" -> "รถเครน")
  const types = new Set();
  const sizes = new Set();
  partners.forEach(p=> p.tags.forEach(t=>{
    const base = tagDisplayText(t); // strip @price suffix
    // Type: everything before " x<number>"
    const type = base.split(' x')[0].trim();
    if(type) types.add(type);
    // Size: text inside parentheses e.g. "เครน 25 ตัน", "รถขุดขนาด 3 ตัน (PC30)"
    const sz = extractSize(t);
    if(sz) sizes.add(sz);
  }));
  const sortedTypes = Array.from(types).sort((a,b)=> a.localeCompare(b, 'th'));
  const sortedSizes = Array.from(sizes).sort((a,b)=> a.localeCompare(b, 'th'));

  // Collect unique areas
  const areas = new Set();
  partners.forEach(p=> { if(p.area) areas.add(p.area); });
  const sortedAreas = Array.from(areas).sort((a,b)=> a.localeCompare(b, 'th'));

  // Populate Category dropdowns (preserve current selection if still valid)
  ['filterCategory','mapFilterCategory'].forEach(id=>{
    const sel = document.getElementById(id);
    if(!sel) return;
    const current = sel.value;
    sel.innerHTML = '<option>All categories</option>' +
      sortedTypes.map(t=> `<option>${t}</option>`).join('');
    if(sortedTypes.includes(current)) sel.value = current;
  });

  // Populate Size dropdown — dynamically updates when Category is selected
  // so only sizes relevant to the chosen type are shown
  const updateSizeOptions = ()=>{
    const sel = document.getElementById('filterSize');
    if(!sel) return;
    const currentSize = sel.value;
    const activeCat = document.getElementById('filterCategory')?.value || 'All categories';

    // Collect sizes relevant to the currently-selected category
    const filteredSizes = new Set();
    partners.forEach(p=> p.tags.forEach(t=>{
      const base = tagDisplayText(t);
      const type = base.split(' x')[0].trim();
      if(activeCat !== 'All categories' && type !== activeCat) return;
      const sz = extractSize(t);
      if(sz) filteredSizes.add(sz);
    }));
    const sortedFiltered = Array.from(filteredSizes).sort((a,b)=> a.localeCompare(b,'th'));
    sel.innerHTML = '<option>All sizes</option>' +
      sortedFiltered.map(s=> `<option>${s}</option>`).join('');
    if(filteredSizes.has(currentSize)) sel.value = currentSize;
  };

  updateSizeOptions();
  // Re-run size filter when category changes
  const catSel = document.getElementById('filterCategory');
  if(catSel && !catSel._sizeListenerAttached){
    catSel.addEventListener('change', ()=>{ updateSizeOptions(); renderPartners(); });
    catSel._sizeListenerAttached = true;
  }

  // Populate Area dropdowns
  ['filterArea','mapFilterArea'].forEach(id=>{
    const sel = document.getElementById(id);
    if(!sel) return;
    const current = sel.value;
    sel.innerHTML = '<option>All areas</option>' +
      sortedAreas.map(a=> `<option>${a}</option>`).join('');
    if(sortedAreas.includes(current)) sel.value = current;
  });
}

// Normalize area names — consolidate English/Thai duplicates (e.g. "Bangkok" -> "กรุงเทพ")
function normalizeArea(area){
  if(!area) return area;
  const a = area.toString().trim();
  if(a.toLowerCase() === 'bangkok') return 'กรุงเทพ';
  return a;
}

function rebuildSummaries(){
  rebuildFilterOptions();

  const areaCounts = {};
  partners.forEach(p=>{
    const area = normalizeArea(p.area) || p.area;
    areaCounts[area] = areaCounts[area] || {total:0, active:0};
    areaCounts[area].total++;
    if(p.status==='active') areaCounts[area].active++;
  });
  document.getElementById('areaSummary').innerHTML = Object.entries(areaCounts).map(([area,c])=>`
    <div class="area-row">
      <div><div>${area}</div><div class="sub">${c.active}/${c.total} active</div></div>
      <div class="val">${c.total}</div>
    </div>`).join('');

  // Equipment summary: dynamic per actual equipment type (Thai labels from data)
  const equipCounts = {};
  let totalAllEquip = 0;
  partners.forEach(p=>p.tags.forEach(t=>{
    const base = tagDisplayText(t);
    const m = base.match(/^(.+?)\s*x(\d+)/);
    if(m){
      const type = m[1].trim();
      const qty = parseInt(m[2]) || 0;
      totalAllEquip += qty;
      equipCounts[type] = (equipCounts[type] || 0) + qty;
    }
  }));
  const sortedEquip = Object.entries(equipCounts).sort((a,b)=> b[1]-a[1]);
  document.getElementById('equipSummary').innerHTML = sortedEquip.length
    ? sortedEquip.map(([k,v])=>`
        <div class="equip-row"><span>${k}</span><span style="font-weight:600;">${v} units</span></div>`).join('')
    : '<div style="font-size:12px; color:var(--text3);">No equipment data</div>';

  rebuildStats(equipCounts, totalAllEquip);
}

function rebuildStats(equipCounts, totalAllEquip){
  const total = partners.length;
  const active = partners.filter(p=>p.status==='active').length;
  const pending = partners.filter(p=>p.status==='pending').length;
  const totalEquip = totalAllEquip || Object.values(equipCounts).reduce((a,b)=>a+b, 0);

  document.getElementById('statTotalPartners').textContent = total;
  document.getElementById('statActive').textContent = active;
  document.getElementById('statPending').textContent = pending;
  document.getElementById('statEquipment').textContent = totalEquip;
}

