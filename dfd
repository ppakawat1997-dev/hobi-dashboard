            ${badge}
            <div class="card-actions">
              <div class="card-action-btn edit-btn" title="Edit"><i class="ti ti-edit"></i></div>
              <div class="card-action-btn danger delete-btn" title="Delete"><i class="ti ti-trash"></i></div>
            </div>
          </div>
        </div>
        <div class="partner-info"><i class="ti ti-phone"></i> ${p.phone}</div>
        <div class="partner-info"><i class="ti ti-map-pin"></i> ${p.area}</div>
        <div class="partner-tags">${p.tags.map(t=>`<span class="tag">${tagDisplayText(t)}</span>`).join('')}</div>
        <div class="partner-price">Price: ${p.price} THB / day</div>
      </div>`;
  });

  grid.querySelectorAll('.partner-card').forEach(card=>{
    const id = parseInt(card.dataset.id);
    card.addEventListener('click', (e)=>{
