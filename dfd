const CSV_HEADERS = ["id","name","contact","phone","email","area","status","tags","price","lat","lng","address","notes"];

function partnersToCSV(){
  const rows = [CSV_HEADERS.join(",")];
  partners.forEach(p=>{
    const row = [
      p.id, `"${p.name}"`, `"${p.contact||''}"`, p.phone, p.email||'', p.area, p.status,
      `"${p.tags.join('; ')}"`, `"${p.price}"`, p.lat, p.lng,
      `"${(p.address||'').replace(/"/g,'""')}"`, `"${(p.notes||'').replace(/"/g,'""')}"`
    ];
    rows.push(row.join(","));
  });
